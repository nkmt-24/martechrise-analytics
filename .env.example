# ==============================================================================
# ENVIRONMENT VARIABLES CONFIGURATION (.env.local)
# Copy this file to .env.local and update the values before running the app.
# ==============================================================================

# ------------------------------------------------------------------------------
# CORE APPLICATION
# ------------------------------------------------------------------------------
NEXT_PUBLIC_APP_NAME="Portfolio Name"
NEXT_PUBLIC_APP_TAGLINE="Building Digital Excellence"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ------------------------------------------------------------------------------
# CONTACT & COMPANY INFO
# ------------------------------------------------------------------------------
NEXT_PUBLIC_CONTACT_EMAIL="hello@example.com"
NEXT_PUBLIC_CONTACT_PHONE="+1 (555) 123-4567"
NEXT_PUBLIC_COMPANY_ADDRESS="123 Main St, City, Country"

# ------------------------------------------------------------------------------
# SOCIAL MEDIA HANDLES (Optional)
# ------------------------------------------------------------------------------
NEXT_PUBLIC_TWITTER_HANDLE="@yourhandle"
NEXT_PUBLIC_LINKEDIN_URL="https://linkedin.com/company/yourcompany"
NEXT_PUBLIC_GITHUB_URL="https://github.com/yourorg"
# NEXT_PUBLIC_FACEBOOK_URL=""
# NEXT_PUBLIC_INSTAGRAM_URL=""

# ------------------------------------------------------------------------------
# DATABASE (MongoDB)
# ------------------------------------------------------------------------------
# MongoDB connection string (Required for data persistence)
MONGODB_URI="mongodb+srv://<user>:<password>@cluster.mongodb.net/your_db?retryWrites=true&w=majority"

# ------------------------------------------------------------------------------
# AUTHENTICATION (NextAuth)
# ------------------------------------------------------------------------------
# Secret key for encrypting sessions. Generate via: openssl rand -base64 32
NEXTAUTH_SECRET="your_secure_random_string_here"
# The base URL of your application for NextAuth callbacks
NEXTAUTH_URL="http://localhost:3000"

# ------------------------------------------------------------------------------
# MEDIA STORAGE (Cloudinary)
# ------------------------------------------------------------------------------
# Cloudinary credentials for handling image uploads
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME="your_cloud_name"
CLOUDINARY_API_KEY="your_api_key"
CLOUDINARY_API_SECRET="your_api_secret"

# ------------------------------------------------------------------------------
# BLOG CONFIGURATION
# ------------------------------------------------------------------------------
NEXT_PUBLIC_BLOG_PER_PAGE=12
NEXT_PUBLIC_BLOG_EXCERPT_LENGTH=200

# ------------------------------------------------------------------------------
# INTEGRATIONS & CRON JOBS
# ------------------------------------------------------------------------------
# Webhook secret used to authenticate incoming AI blog generation requests from n8n
N8N_WEBHOOK_SECRET="generate_strong_secret_at_least_32_chars_long"

# Secret used to authenticate internal chron jobs (e.g., checking broken links)
CRON_SECRET="generate_another_strong_secret_here"
